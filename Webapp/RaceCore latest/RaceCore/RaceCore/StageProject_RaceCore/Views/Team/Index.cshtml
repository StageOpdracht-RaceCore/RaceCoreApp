@model IEnumerable<StageProject_RaceCore.Models.TeamViewModel>
@using System.Linq

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Team.css" />

<div class="page-card page-summary">
    <h2>Teams</h2>
    <p>Overview of all pro cycling teams, their rosters, and current points.</p>
</div>

@if (!(Model?.Any() ?? false))
{
    <div class="page-card">
        <h3>No teams found</h3>
        <p>There are currently no teams in the system.</p>
    </div>
}
else
{
    <div class="global-search-bar">
        <input
            type="text"
            id="globalSearchInput"
            placeholder="Search by team or cyclist name&hellip;"
            aria-label="Search teams and cyclists" />
        <button
            type="button"
            id="globalSearchClear"
            title="Clear search"
            hidden>
            &#10005; Clear
        </button>
        <span id="globalSearchCount" aria-live="polite"></span>
    </div>

    <div class="teams-grid teams-grid-wide-gap" id="teamsGrid">
        @foreach (var team in Model.OrderByDescending(t => t.ActiveCyclistsCount + t.BenchCyclistsCount))
        {
            <div
                class="team-card collapsed"
                data-team-id="@team.Id"
                data-team-name="@team.Name.ToLower()">
                <div class="team-header">
                    <div class="team-meta">
                        <span class="swatch"></span>

                        <div>
                            <div class="team-name">
                                @team.Name
                                <span class="tag">@team.Tag</span>
                            </div>

                            <div class="team-cyclist-count">
                                @(team.ActiveCyclistsCount + team.BenchCyclistsCount) cyclists
                            </div>
                        </div>
                    </div>

                    <div class="team-stats">
                        <div class="team-stats-top">
                            <div class="badge">@team.TeamPoints pts</div>
                            <button
                                type="button"
                                class="collapse-toggle"
                                aria-expanded="false"
                                title="Toggle team">
                                <span class="arrow">&#9662;</span>
                            </button>
                        </div>

                        <div class="team-counts">
                            Active: <strong>@team.ActiveCyclistsCount</strong>
                            &middot;
                            Bench: <strong>@team.BenchCyclistsCount</strong>
                        </div>
                    </div>
                </div>

                <div class="team-body">
                    <div class="composition">
                        <div class="column">
                            <h4>Active</h4>

                            @if (team.ActiveCyclists != null && team.ActiveCyclists.Any())
                            {
                                <ul class="cyclist-list">
                                    @foreach (var c in team.ActiveCyclists)
                                    {
                                        <li data-cyclist-name="@($"{c.FirstName} {c.LastName}".ToLower())">
                                            <span>@c.FirstName @c.LastName</span>

                                            <form
                                                asp-controller="Team"
                                                asp-action="ToggleCyclistStatus"
                                                method="post"
                                                class="cyclist-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cyclistId" value="@c.Id" />
                                                <input type="hidden" name="isActive" value="false" />
                                                <button type="submit" class="bench-btn">Bench</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No active cyclists</div>
                            }
                        </div>

                        <div class="column">
                            <h4>Bench</h4>

                            @if (team.BenchCyclists != null && team.BenchCyclists.Any())
                            {
                                <ul class="cyclist-list">
                                    @foreach (var c in team.BenchCyclists)
                                    {
                                        <li data-cyclist-name="@($"{c.FirstName} {c.LastName}".ToLower())">
                                            <span>@c.FirstName @c.LastName</span>

                                            <form
                                                asp-controller="Team"
                                                asp-action="ToggleCyclistStatus"
                                                method="post"
                                                class="cyclist-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cyclistId" value="@c.Id" />
                                                <input type="hidden" name="isActive" value="true" />
                                                <button type="submit" class="activate-btn">Activate</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No cyclists on the bench</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        (function () {
            // Collapse state (localStorage)
            var STORAGE_KEY = "teamsCollapseState";

            function readState() {
                try {
                    return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
                } catch (e) {
                    return {};
                }
            }

            function writeState(state) {
                try {
                    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
                } catch (e) {
                }
            }

            function saveCardState(card) {
                var id = card.dataset.teamId;
                if (!id) {
                    return;
                }

                var state = readState();
                state[id] = card.classList.contains("collapsed");
                writeState(state);
            }

            function restoreAll() {
                var state = readState();

                document.querySelectorAll(".team-card[data-team-id]").forEach(function (card) {
                    var id = card.dataset.teamId;
                    if (!id) {
                        return;
                    }

                    var collapsed = state.hasOwnProperty(id) ? state[id] : true;
                    card.classList.toggle("collapsed", collapsed);

                    var btn = card.querySelector(".collapse-toggle");
                    if (btn) {
                        btn.setAttribute("aria-expanded", String(!collapsed));
                    }
                });
            }

            // Team accent colours (stable per id, saved to localStorage)
            function hashToInt(str) {
                var h = 2166136261 >>> 0;

                for (var i = 0; i < str.length; i++) {
                    h ^= str.charCodeAt(i);
                    h = Math.imul(h, 16777619) >>> 0;
                }

                return h >>> 0;
            }

            (function assignColors() {
                var MIN_DIFF = 60;
                var GOLDEN = 137.508;
                var usedHues = [];

                function hueDist(a, b) {
                    var d = Math.abs(a - b) % 360;
                    return d > 180 ? 360 - d : d;
                }

                document.querySelectorAll(".team-card[data-team-id]").forEach(function (card, i) {
                    var id = card.dataset.teamId;
                    var key = "teamColor_" + id;
                    var saved = null;

                    try {
                        saved = localStorage.getItem(key);
                    } catch (e) {
                    }

                    if (saved) {
                        card.style.setProperty("--team-color", saved);

                        var m = saved.match(/hsl\(([-\d.]+)/i);
                        if (m) {
                            usedHues.push(parseFloat(m[1]));
                        }
                    } else {
                        var candidate = (hashToInt(String(id)) % 360 + i * GOLDEN) % 360;
                        var tries = 0;

                        while (
                            usedHues.some(function (h) {
                                return hueDist(h, candidate) < MIN_DIFF;
                            })
                        ) {
                            candidate = (candidate + GOLDEN) % 360;
                            if (++tries > 36) {
                                break;
                            }
                        }

                        var color = "hsl(" + candidate.toFixed(1) + ",65%,55%)";
                        card.style.setProperty("--team-color", color);

                        try {
                            localStorage.setItem(key, color);
                        } catch (e) {
                        }

                        usedHues.push(candidate);
                    }

                    var swatch = card.querySelector(".swatch");
                    if (swatch) {
                        swatch.style.background = "var(--team-color)";
                    }
                });
            })();

            restoreAll();

            // Collapse / expand on header click
            document.addEventListener("click", function (e) {
                var toggleBtn = e.target.closest(".collapse-toggle");

                if (toggleBtn) {
                    var card = toggleBtn.closest(".team-card");
                    if (!card) {
                        return;
                    }

                    var collapsed = card.classList.toggle("collapsed");
                    toggleBtn.setAttribute("aria-expanded", String(!collapsed));
                    saveCardState(card);
                    return;
                }

                var header = e.target.closest(".team-header");
                if (header && !e.target.closest("button, a, form")) {
                    var card = header.closest(".team-card");
                    if (!card) {
                        return;
                    }

                    var collapsed = card.classList.toggle("collapsed");
                    var btn = card.querySelector(".collapse-toggle");

                    if (btn) {
                        btn.setAttribute("aria-expanded", String(!collapsed));
                    }

                    saveCardState(card);
                }
            });

            // Save state before a bench/activate form submits
            document.addEventListener(
                "click",
                function (e) {
                    if (!e.target.closest(".bench-btn, .activate-btn")) {
                        return;
                    }

                    var state = {};

                    document.querySelectorAll(".team-card[data-team-id]").forEach(function (card) {
                        var id = card.dataset.teamId;
                        if (id) {
                            state[id] = card.classList.contains("collapsed");
                        }
                    });

                    writeState(state);
                },
                true
            );

            // Global search
            var searchInput = document.getElementById("globalSearchInput");
            var clearBtn = document.getElementById("globalSearchClear");
            var countEl = document.getElementById("globalSearchCount");

            if (!searchInput) {
                return;
            }

            function removeDynamicEmpties() {
                document.querySelectorAll(".search-empty").forEach(function (el) {
                    el.remove();
                });
            }

            function expandCard(card) {
                if (!card.classList.contains("collapsed")) {
                    return;
                }

                card.classList.remove("collapsed");

                var btn = card.querySelector(".collapse-toggle");
                if (btn) {
                    btn.setAttribute("aria-expanded", "true");
                }

                saveCardState(card);
            }

            function applyFilter(query) {
                query = query.trim().toLowerCase();
                removeDynamicEmpties();

                var totalVisible = 0;

                document.querySelectorAll(".team-card[data-team-id]").forEach(function (card) {
                    var teamName = card.dataset.teamName || "";
                    var items = Array.from(
                        card.querySelectorAll(".cyclist-list li[data-cyclist-name]")
                    );

                    if (query === "") {
                        items.forEach(function (li) {
                            li.hidden = false;
                        });

                        card.hidden = false;
                        totalVisible += items.length;
                        return;
                    }

                    var teamMatches = teamName.includes(query);
                    var cyclistMatches = 0;

                    items.forEach(function (li) {
                        var match = (li.dataset.cyclistName || "").includes(query);
                        li.hidden = !match;

                        if (match) {
                            cyclistMatches++;
                        }
                    });

                    if (teamMatches) {
                        card.hidden = false;

                        items.forEach(function (li) {
                            li.hidden = false;
                        });

                        totalVisible += items.length;
                        expandCard(card);
                    } else if (cyclistMatches > 0) {
                        card.hidden = false;
                        totalVisible += cyclistMatches;
                        expandCard(card);

                        card.querySelectorAll(".column").forEach(function (col) {
                            var list = col.querySelector(".cyclist-list");
                            if (!list) {
                                return;
                            }

                            var allHidden = Array.from(list.querySelectorAll("li")).every(function (li) {
                                return li.hidden;
                            });

                            if (allHidden) {
                                var msg = document.createElement("div");
                                msg.className = "empty search-empty";
                                msg.textContent = "No matches";
                                col.appendChild(msg);
                            }
                        });
                    } else {
                        card.hidden = true;
                    }
                });

                if (query === "") {
                    clearBtn.hidden = true;
                    countEl.textContent = "";
                } else {
                    clearBtn.hidden = false;
                    countEl.textContent =
                        totalVisible > 0
                            ? totalVisible + " cyclist" + (totalVisible !== 1 ? "s" : "") + " found"
                            : "No results";
                }
            }

            searchInput.addEventListener("input", function () {
                applyFilter(searchInput.value);
            });

            clearBtn.addEventListener("click", function () {
                searchInput.value = "";
                applyFilter("");
                searchInput.focus();
            });
        })();
    </script>
}
