@model StageProject_RaceCore.Models.Player

@{
    ViewData["Title"] = "Speler verwijderen";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2>Speler verwijderen</h2>

<div class="alert alert-danger">
    Ben je zeker dat je <strong>@Model.Name</strong> wil verwijderen?
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Verwijderen</button>
    <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
</form>